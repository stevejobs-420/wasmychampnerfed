{
  "name": "wasmychampnerfed",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "When was a LoL champion last buffed/nerfed? Scrapes official patch notes into a static dataset.",
  "scripts": {
    "ingest": "tsx src/ingest.ts",
